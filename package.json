{
  "name": "recoding-assignment",
  "private": true,
  "packageManager": "npm@10.8.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "dev:web": "turbo run dev --filter=web",
    "dev:server": "turbo run dev --filter=server",
    "check-types": "turbo run check-types",
    "db:push": "dotenv -e apps/server/.env -- npm run --prefix packages/db _db:push",
    "db:generate": "dotenv -e apps/server/.env -- npm run --prefix packages/db _db:generate",
    "db:migrate": "dotenv -e apps/server/.env -- drizzle-kit migrate --config=packages/db/drizzle.config.ts",
    "db:studio": "dotenv -e apps/server/.env -- npm run --prefix packages/db _db:studio"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "drizzle-kit": "^0.21.4",
    "drizzle-orm": "^0.30.10",
    "postgres": "^3.4.4",
    "ts-node": "^10.9.2",
    "turbo": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  }
}
